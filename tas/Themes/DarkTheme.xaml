<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Кисти -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="#1E1E1E"/>
    <SolidColorBrush x:Key="ForegroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#2D2D2D"/>
    <SolidColorBrush x:Key="ButtonBackgroundBrush" Color="#3D3D3D"/>
    <SolidColorBrush x:Key="ButtonForegroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="DataGridBackgroundBrush" Color="#252525"/>
    <SolidColorBrush x:Key="DataGridHeaderBackgroundBrush" Color="#3A3A3A"/>
    <SolidColorBrush x:Key="DataGridRowBackgroundBrush" Color="#2D2D2D"/>
    <SolidColorBrush x:Key="DataGridAlternatingRowBackgroundBrush" Color="#3A3A3A"/>
    <SolidColorBrush x:Key="DataGridCellForegroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ComboBoxBackgroundBrush" Color="#1E1E1E"/>
    <SolidColorBrush x:Key="ComboBoxItemBackgroundBrush" Color="#1E1E1E"/>
    <SolidColorBrush x:Key="ComboBoxItemForegroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="TextBoxBackgroundBrush" Color="#1E1E1E"/>
    <SolidColorBrush x:Key="TextBoxForegroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="DatePickerBackgroundBrush" Color="#1E1E1E"/>
    <SolidColorBrush x:Key="DatePickerForegroundBrush" Color="#FFFFFF"/>

    <!-- Стиль для DataGridHeader -->
    <Style x:Key="DataGridHeaderStyle" TargetType="DataGridColumnHeader">
        <Setter Property="Background" Value="{StaticResource DataGridHeaderBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource ForegroundBrush}"/>
    </Style>

    <!-- DataGrid -->
    <Style TargetType="DataGrid">
        <Setter Property="Background" Value="{StaticResource DataGridBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource ForegroundBrush}"/>
        <Setter Property="RowBackground" Value="{StaticResource DataGridRowBackgroundBrush}"/>
        <Setter Property="AlternatingRowBackground" Value="{StaticResource DataGridAlternatingRowBackgroundBrush}"/>
    </Style>

    <!-- DataGridCell -->
    <Style TargetType="DataGridCell">
        <Setter Property="Background" Value="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=Background}"/>
        <Setter Property="Foreground" Value="{StaticResource DataGridCellForegroundBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource ForegroundBrush}"/>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{StaticResource DataGridHeaderBackgroundBrush}"/>
                <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- DataGridRow -->
    <Style TargetType="DataGridRow">
        <Setter Property="Background" Value="{StaticResource DataGridRowBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource DataGridCellForegroundBrush}"/>
        <Style.Triggers>
            <Trigger Property="AlternationIndex" Value="1">
                <Setter Property="Background" Value="{StaticResource DataGridAlternatingRowBackgroundBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ComboBoxItem -->
    <Style TargetType="ComboBoxItem">
        <Setter Property="Background" Value="{StaticResource ComboBoxItemBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource ComboBoxItemForegroundBrush}"/>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{StaticResource DataGridHeaderBackgroundBrush}"/>
                <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}"/>
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource DataGridHeaderBackgroundBrush}"/>
                <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- TextBox -->
    <Style TargetType="TextBox">
        <Setter Property="Background" Value="{StaticResource TextBoxBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextBoxForegroundBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource ForegroundBrush}"/>
    </Style>

    <!-- PasswordBox -->
    <Style TargetType="PasswordBox">
        <Setter Property="Background" Value="{StaticResource TextBoxBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextBoxForegroundBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource ForegroundBrush}"/>
    </Style>

    <!-- DatePicker -->
    <Style TargetType="DatePicker">
        <Setter Property="Background" Value="{StaticResource DatePickerBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource DatePickerForegroundBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource ForegroundBrush}"/>
    </Style>

    <!-- DatePickerTextBox -->
    <Style TargetType="DatePickerTextBox">
        <Setter Property="Background" Value="{StaticResource DatePickerBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource DatePickerForegroundBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource ForegroundBrush}"/>
    </Style>

</ResourceDictionary>