<Window x:Class="tas.UI.TaskEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактирование задачи" Height="450" Width="500"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="{DynamicResource ForegroundBrush}">
    <StackPanel Margin="20">
        <Label Content="Название" Foreground="{DynamicResource ForegroundBrush}"/>
        <TextBox x:Name="tbTitle" Margin="0,0,0,10"
                 Background="{DynamicResource BackgroundBrush}"
                 Foreground="{DynamicResource ForegroundBrush}"/>

        <Label Content="Описание" Foreground="{DynamicResource ForegroundBrush}"/>
        <TextBox x:Name="tbDescription" TextWrapping="Wrap" Height="80" Margin="0,0,0,10"
                 Background="{DynamicResource BackgroundBrush}"
                 Foreground="{DynamicResource ForegroundBrush}"/>

        <Label Content="Исполнитель" Foreground="{DynamicResource ForegroundBrush}"/>
        <ComboBox x:Name="cbExecutor" DisplayMemberPath="Login" SelectedValuePath="Id" Margin="0,0,0,10"
                  Background="{DynamicResource BackgroundBrush}"
                  Foreground="{DynamicResource ForegroundBrush}"/>

        <Label Content="Срок выполнения" Foreground="{DynamicResource ForegroundBrush}"/>
        <DatePicker x:Name="dpDeadline" Margin="0,0,0,10"
                    Background="{DynamicResource BackgroundBrush}"
                    Foreground="{DynamicResource ForegroundBrush}"/>

        <Label Content="Статус" Foreground="{DynamicResource ForegroundBrush}"/>
        <ComboBox x:Name="cbStatus" DisplayMemberPath="Name" SelectedValuePath="Id" Margin="0,0,0,15"
                  Background="{DynamicResource BackgroundBrush}"
                  Foreground="{DynamicResource ForegroundBrush}"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Content="Сохранить" Width="100" Margin="0,0,10,0" Click="Save_Click"
                    Background="{DynamicResource ButtonBackgroundBrush}"
                    Foreground="{DynamicResource ButtonForegroundBrush}"/>
            <Button Content="Отмена" Width="100" Click="Cancel_Click"
                    Background="{DynamicResource ButtonBackgroundBrush}"
                    Foreground="{DynamicResource ButtonForegroundBrush}"/>
        </StackPanel>
    </StackPanel>
</Window>